@page "/"

<PageTitle>HomeScout Copilot</PageTitle>

<main class="container py-4">
    <section class="row align-items-start g-4">
        <div class="col-lg-7">
            <h1>HomeScout Copilot</h1>
            <p class="lead">
                Compare properties and neighbourhoods with an AI assistant that can reason over public data,
                uploaded documents, and your buying priorities.
            </p>

            <div class="card">
                <div class="card-body">
                    <label for="comparisonPrompt" class="form-label">Start a comparison</label>
                    <textarea id="comparisonPrompt"
                              class="form-control"
                              rows="5"
                              placeholder="Compare a 2-bed flat in SE10 with one in CR0. I care about commute, schools, crime, parks, and monthly costs."></textarea>
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-primary" type="button">Ask HomeScout</button>
                        <button class="btn btn-outline-secondary" type="button">Attach listing</button>
                    </div>
                </div>
            </div>
        </div>

        <aside class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5">MVP focus</h2>
                    <ul class="mb-0">
                        <li>Area comparison</li>
                        <li>Crime and amenities lookup</li>
                        <li>School context</li>
                        <li>Ownership cost estimates</li>
                        <li>Saved buyer preferences</li>
                    </ul>
                </div>
            </div>
        </aside>
    </section>
</main>
